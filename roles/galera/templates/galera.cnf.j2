[mysqld]
binlog_format=ROW
default_storage_engine=InnoDB
innodb_autoinc_lock_mode=2
bind-address={{ librenms_db_bind_address }}

wsrep_on=ON
wsrep_provider=/usr/lib/galera/libgalera_smm.so

wsrep_cluster_name="{{ librenms_galera_cluster_name }}"
wsrep_cluster_address="gcomm://{% for host in librenms_active_db_nodes %}{{ hostvars[host].ansible_host | default(host) }}{% if not loop.last %},{% endif %}{% endfor %}"

wsrep_sst_method={{ librenms_galera_sst_method }}

wsrep_node_address="{{ ansible_host | default(inventory_hostname) }}"
wsrep_node_name="{{ inventory_hostname }}"
