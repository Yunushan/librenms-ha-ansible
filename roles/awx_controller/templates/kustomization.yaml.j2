---
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - {{ awx_controller_operator_source | to_json }}
  - awx.yml
images:
  - name: quay.io/ansible/awx-operator
    newTag: {{ awx_controller_operator_version | to_json }}
namespace: {{ awx_controller_namespace | to_json }}
