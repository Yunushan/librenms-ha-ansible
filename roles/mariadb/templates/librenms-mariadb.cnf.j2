[mysqld]
innodb_file_per_table=1
lower_case_table_names=0
log_warnings={{ librenms_mariadb_log_warnings }}
bind-address={{
  (
    ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname))
  )
  if (
    inventory_hostname in (
      groups.get('lb_nodes', [])
      | difference(librenms_inactive_inventory_nodes)
    )
    and librenms_db_bind_address in ['0.0.0.0', '::', '']
  )
  else librenms_db_bind_address
}}
