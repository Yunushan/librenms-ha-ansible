[Unit]
Description=LibreNMS Redis Sentinel
After=network.target {{ librenms_redis_service_name }}.service
Requires={{ librenms_redis_service_name }}.service

[Service]
Type=simple
ExecStart=/usr/bin/redis-server {{ librenms_redis_sentinel_conf_path }} --sentinel
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
